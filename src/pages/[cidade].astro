---
import Layout from '../layouts/Layout.astro';
import cidades from '../data/cidades.json';

export function getStaticPaths() {
  return cidades.map((c) => ({
    params: { cidade: c.slug },
    props: { cidade: c },
  }));
}

const { cidade: c } = Astro.props;

// Image paths (assets are copied to /public/images/ at build)
const assets = {
  logo: '/images/logo-riviera-DzPkbkD9.jpg',
  hero: '/images/hero-jewelry-BvgQUVJ1.jpg',
  correntes: '/images/item-correntes-BPAOxieA.jpg',
  aneis: '/images/item-aneis-CZLYbggN.jpg',
  pulseiras: '/images/item-pulseiras-ByIh7EQE.jpg',
  brincos: '/images/item-brincos--neZJSdU.jpg',
  relogios: '/images/item-relogios-uhcWfNzM.jpg',
  ouroQuebrado: '/images/item-ouro-quebrado-XSrMlOmA.jpg',
  ouroAntigo: '/images/item-ouro-antigo-C5reThlg.jpg',
  sucata: '/images/item-sucata-C-2AfJAI.jpg',
};

const items = [
  { src: assets.correntes, alt: 'Correntes de ouro', label: 'Correntes de ouro' },
  { src: assets.aneis,     alt: 'Anéis',             label: 'Anéis' },
  { src: assets.pulseiras, alt: 'Pulseiras',          label: 'Pulseiras' },
  { src: assets.brincos,   alt: 'Brincos',            label: 'Brincos' },
  { src: assets.relogios,  alt: 'Relógios',           label: 'Relógios' },
  { src: assets.ouroQuebrado, alt: 'Ouro quebrado',   label: 'Ouro quebrado' },
  { src: assets.ouroAntigo,   alt: 'Ouro antigo',     label: 'Ouro antigo' },
  { src: assets.sucata,    alt: 'Sucata de ouro',     label: 'Sucata de ouro' },
];
---

<Layout
  title={c.seo.title}
  description={c.seo.description}
  canonical={c.seo.canonical}
  ogImage={c.seo.ogImage}
  cidade={c.cidade}
  estado={c.estado}
  telefoneRaw={c.telefoneRaw}
  endereco={c.endereco}
  complemento={c.complemento}
  cep={c.cep}
  geoLat={c.geoLat}
  geoLng={c.geoLng}
  instagram={c.instagram}
  horario={c.horarioFuncionamento}
>
  <div class="min-h-screen" style="background-color:#121212; color:#EDE9DE;">

    <!-- ===== HEADER ===== -->
    <header style="position:fixed;top:0;left:0;right:0;z-index:50;background:rgba(18,18,18,0.95);backdrop-filter:blur(12px);border-bottom:1px solid #2a2a2a;">
      <div style="max-width:1280px;margin:0 auto;padding:0 1rem;display:flex;align-items:center;justify-content:space-between;height:4rem;">
        <a href="#inicio" style="display:flex;align-items:center;gap:0.75rem;">
          <img src={assets.logo} alt="Riviera - Compra de Ouro e Acessórios" style="height:3.5rem;border-radius:0.375rem;" />
        </a>
        <nav style="display:none;gap:2rem;" class="desktop-nav">
          <a href="#inicio" style="font-size:0.875rem;font-weight:500;color:rgba(237,233,222,0.7);text-decoration:none;" onmouseover="this.style.color='#DFB03A'" onmouseout="this.style.color='rgba(237,233,222,0.7)'">Início</a>
          <a href="#como-funciona" style="font-size:0.875rem;font-weight:500;color:rgba(237,233,222,0.7);text-decoration:none;" onmouseover="this.style.color='#DFB03A'" onmouseout="this.style.color='rgba(237,233,222,0.7)'">Como funciona</a>
          <a href="#o-que-compramos" style="font-size:0.875rem;font-weight:500;color:rgba(237,233,222,0.7);text-decoration:none;" onmouseover="this.style.color='#DFB03A'" onmouseout="this.style.color='rgba(237,233,222,0.7)'">O que compramos</a>
          <a href="#vantagens" style="font-size:0.875rem;font-weight:500;color:rgba(237,233,222,0.7);text-decoration:none;" onmouseover="this.style.color='#DFB03A'" onmouseout="this.style.color='rgba(237,233,222,0.7)'">Vantagens</a>
          <a href="#localizacao" style="font-size:0.875rem;font-weight:500;color:rgba(237,233,222,0.7);text-decoration:none;" onmouseover="this.style.color='#DFB03A'" onmouseout="this.style.color='rgba(237,233,222,0.7)'">Localização</a>
          <a href="#contato" style="font-size:0.875rem;font-weight:500;color:rgba(237,233,222,0.7);text-decoration:none;" onmouseover="this.style.color='#DFB03A'" onmouseout="this.style.color='rgba(237,233,222,0.7)'">Contato</a>
        </nav>
        <div style="display:flex;align-items:center;gap:1rem;">
          <a href={c.whatsappLink} target="_blank" rel="noopener noreferrer" class="btn-gold desktop-cta"
            style="padding:0.625rem 1.25rem;font-size:0.875rem;font-weight:600;border-radius:0.5rem;text-decoration:none;color:#121212;display:none;align-items:center;gap:0.5rem;">
            Falar no WhatsApp
          </a>
          <button id="menu-btn" aria-label="Menu" style="background:none;border:none;cursor:pointer;color:#EDE9DE;padding:0.5rem;display:block;" class="mobile-menu-btn">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="4" x2="20" y1="12" y2="12"></line>
              <line x1="4" x2="20" y1="6" y2="6"></line>
              <line x1="4" x2="20" y1="18" y2="18"></line>
            </svg>
          </button>
        </div>
      </div>
      <!-- Mobile menu -->
      <div id="mobile-menu" style="display:none;padding:1rem;border-top:1px solid #2a2a2a;flex-direction:column;gap:1rem;">
        <a href="#inicio" style="color:rgba(237,233,222,0.7);text-decoration:none;font-size:0.875rem;" onclick="document.getElementById('mobile-menu').style.display='none'">Início</a>
        <a href="#como-funciona" style="color:rgba(237,233,222,0.7);text-decoration:none;font-size:0.875rem;" onclick="document.getElementById('mobile-menu').style.display='none'">Como funciona</a>
        <a href="#o-que-compramos" style="color:rgba(237,233,222,0.7);text-decoration:none;font-size:0.875rem;" onclick="document.getElementById('mobile-menu').style.display='none'">O que compramos</a>
        <a href="#vantagens" style="color:rgba(237,233,222,0.7);text-decoration:none;font-size:0.875rem;" onclick="document.getElementById('mobile-menu').style.display='none'">Vantagens</a>
        <a href="#localizacao" style="color:rgba(237,233,222,0.7);text-decoration:none;font-size:0.875rem;" onclick="document.getElementById('mobile-menu').style.display='none'">Localização</a>
        <a href={c.whatsappLink} target="_blank" rel="noopener noreferrer" class="btn-gold" style="display:inline-block;padding:0.625rem 1.25rem;font-size:0.875rem;font-weight:600;border-radius:0.5rem;text-decoration:none;color:#121212;text-align:center;margin-top:0.5rem;">
          Falar no WhatsApp
        </a>
      </div>
    </header>

    <main>

      <!-- ===== HERO ===== -->
      <section id="inicio" style="position:relative;min-height:100vh;display:flex;align-items:center;justify-content:center;overflow:hidden;">
        <div style="position:absolute;inset:0;">
          <img src={assets.hero} alt={`Joias de ouro - correntes, anéis, pulseiras e relógios em ${c.cidade}`}
            style="width:100%;height:100%;object-fit:cover;" loading="eager" />
          <div style="position:absolute;inset:0;background:rgba(18,18,18,0.75);"></div>
          <div style="position:absolute;inset:0;background:linear-gradient(to top, #121212 0%, rgba(18,18,18,0.4) 40%, transparent 100%);"></div>
        </div>
        <div style="position:relative;z-index:10;max-width:1280px;margin:0 auto;padding:5rem 1rem 3rem;text-align:center;">
          <img src={assets.logo} alt="Riviera - Compra de Ouro e Acessórios"
            style="height:6rem;margin:0 auto 2rem;display:block;border-radius:0.375rem;" />
          <div style="display:inline-block;margin-bottom:1.5rem;padding:0.375rem 1rem;border:1px solid rgba(223,176,58,0.3);border-radius:9999px;">
            <span style="font-size:0.875rem;font-weight:500;color:#DFB03A;">{c.cidade} – {c.estado} • Centro da Cidade</span>
          </div>
          <h1 class="font-serif" style="font-size:clamp(2rem,5vw,4.5rem);font-weight:700;line-height:1.15;margin-bottom:1.5rem;max-width:56rem;margin-left:auto;margin-right:auto;">
            Compra de ouro em {c.cidade} com a <span class="text-gradient-gold">melhor cotação</span>
          </h1>
          <div style="max-width:42rem;margin:0 auto 2.5rem;">
            <p style="font-size:clamp(1.1rem,2.5vw,1.5rem);font-weight:700;margin-bottom:0.75rem;" class="text-gradient-gold">
              💰 Pagamos <span style="font-size:clamp(1.5rem,4vw,3rem);font-weight:900;">R$420</span> por grama de ouro maciço (Peças Maciças)
            </p>
            <p style="font-size:1rem;color:#989181;margin-bottom:0.5rem;">{c.textosUnicos.heroParagrafo}</p>
            <p style="font-size:1rem;color:#989181;">Avaliação justa, pagamento rápido e negociação transparente.</p>
          </div>
          <a href={c.whatsappLink} target="_blank" rel="noopener noreferrer" class="btn-gold shadow-gold"
            style="display:inline-flex;align-items:center;gap:0.75rem;padding:1rem 2rem;font-size:1.125rem;font-weight:700;border-radius:0.5rem;text-decoration:none;color:#121212;">
            <svg viewBox="0 0 24 24" style="width:1.5rem;height:1.5rem;fill:currentColor;flex-shrink:0;">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Solicitar cotação no WhatsApp
          </a>
        </div>
      </section>

      <!-- ===== ESPECIALISTAS ===== -->
      <section style="padding:5rem 1rem;background:#1a1a1a;">
        <div style="max-width:48rem;margin:0 auto;text-align:center;">
          <h2 class="font-serif" style="font-size:clamp(1.75rem,3.5vw,2.5rem);font-weight:700;margin-bottom:1.5rem;">
            Especialistas em <span class="text-gradient-gold">compra de ouro</span> em {c.cidade}
          </h2>
          <p style="color:#989181;font-size:1.125rem;line-height:1.75;margin-bottom:1rem;">{c.textosUnicos.especialistaParagrafo}</p>
          <p style="color:#989181;font-size:1.125rem;line-height:1.75;">{c.textosUnicos.especialistaParagrafo2}</p>
        </div>
      </section>

      <!-- ===== COMO FUNCIONA ===== -->
      <section id="como-funciona" style="padding:5rem 1rem;background:#121212;">
        <div style="max-width:1280px;margin:0 auto;">
          <h2 class="font-serif" style="font-size:clamp(1.75rem,3.5vw,2.5rem);font-weight:700;text-align:center;margin-bottom:4rem;">
            Como <span class="text-gradient-gold">funciona</span>
          </h2>
          <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:2rem;max-width:56rem;margin:0 auto;">

            <!-- Step 1 -->
            <div class="card-dark glow-gold" style="text-align:center;padding:2rem;border-radius:0.75rem;border:1px solid #2a2a2a;transition:border-color 0.2s;">
              <div style="width:4rem;height:4rem;border-radius:50%;background:rgba(223,176,58,0.1);display:flex;align-items:center;justify-content:center;margin:0 auto 1.25rem;">
                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#DFB03A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M11 21.73a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73z"></path>
                  <path d="M12 22V12"></path><path d="m3.3 7 7.703 4.734a2 2 0 0 0 1.994 0L20.7 7"></path><path d="m7.5 4.27 9 5.15"></path>
                </svg>
              </div>
              <div style="font-size:0.75rem;font-weight:700;color:#DFB03A;margin-bottom:0.5rem;">Passo 1</div>
              <h3 class="font-serif" style="font-size:1.25rem;font-weight:700;margin-bottom:0.75rem;">Traga seu ouro</h3>
              <p style="color:#989181;font-size:0.875rem;">Traga seus acessórios de ouro até nossa loja no centro de {c.cidade}.</p>
            </div>

            <!-- Step 2 -->
            <div class="card-dark glow-gold" style="text-align:center;padding:2rem;border-radius:0.75rem;border:1px solid #2a2a2a;transition:border-color 0.2s;">
              <div style="width:4rem;height:4rem;border-radius:50%;background:rgba(223,176,58,0.1);display:flex;align-items:center;justify-content:center;margin:0 auto 1.25rem;">
                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#DFB03A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.3-4.3"></path>
                </svg>
              </div>
              <div style="font-size:0.75rem;font-weight:700;color:#DFB03A;margin-bottom:0.5rem;">Passo 2</div>
              <h3 class="font-serif" style="font-size:1.25rem;font-weight:700;margin-bottom:0.75rem;">Avaliação gratuita</h3>
              <p style="color:#989181;font-size:0.875rem;">Realizamos uma avaliação gratuita e transparente do seu ouro.</p>
            </div>

            <!-- Step 3 -->
            <div class="card-dark glow-gold" style="text-align:center;padding:2rem;border-radius:0.75rem;border:1px solid #2a2a2a;transition:border-color 0.2s;">
              <div style="width:4rem;height:4rem;border-radius:50%;background:rgba(223,176,58,0.1);display:flex;align-items:center;justify-content:center;margin:0 auto 1.25rem;">
                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#DFB03A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect width="20" height="12" x="2" y="6" rx="2"></rect><circle cx="12" cy="12" r="2"></circle><path d="M6 12h.01M18 12h.01"></path>
                </svg>
              </div>
              <div style="font-size:0.75rem;font-weight:700;color:#DFB03A;margin-bottom:0.5rem;">Passo 3</div>
              <h3 class="font-serif" style="font-size:1.25rem;font-weight:700;margin-bottom:0.75rem;">Pagamento na hora</h3>
              <p style="color:#989181;font-size:0.875rem;">Receba o pagamento imediatamente, sem burocracia.</p>
            </div>

          </div>
        </div>
      </section>

      <!-- ===== O QUE COMPRAMOS ===== -->
      <section id="o-que-compramos" style="padding:5rem 1rem;background:#1a1a1a;">
        <div style="max-width:1280px;margin:0 auto;">
          <h2 class="font-serif" style="font-size:clamp(1.75rem,3.5vw,2.5rem);font-weight:700;text-align:center;margin-bottom:4rem;">
            O que <span class="text-gradient-gold">compramos</span>
          </h2>
          <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:1rem;max-width:56rem;margin:0 auto;" class="items-grid">
            {items.map((item) => (
              <div class="item-card" style="border-radius:0.75rem;border:1px solid #2a2a2a;overflow:hidden;background:#121212;transition:border-color 0.2s;display:flex;flex-direction:column;align-items:center;">
                <div style="width:100%;aspect-ratio:1;overflow:hidden;">
                  <img src={item.src} alt={item.alt} loading="lazy"
                    style="width:100%;height:100%;object-fit:cover;transition:transform 0.5s;" class="item-img" />
                </div>
                <span style="font-size:0.875rem;font-weight:500;text-align:center;padding:0.75rem 0.5rem;">{item.label}</span>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- ===== VANTAGENS ===== -->
      <section id="vantagens" style="padding:5rem 1rem;background:#121212;">
        <div style="max-width:1280px;margin:0 auto;">
          <h2 class="font-serif" style="font-size:clamp(1.75rem,3.5vw,2.5rem);font-weight:700;text-align:center;margin-bottom:4rem;">
            Nossas <span class="text-gradient-gold">vantagens</span>
          </h2>
          <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:1.5rem;max-width:64rem;margin:0 auto;">

            <div style="text-align:center;padding:1.5rem;">
              <div style="width:3.5rem;height:3.5rem;border-radius:50%;background:rgba(223,176,58,0.1);display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#DFB03A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="22 7 13.5 15.5 8.5 10.5 2 17"></polyline><polyline points="16 7 22 7 22 13"></polyline>
                </svg>
              </div>
              <h3 class="font-serif" style="font-size:0.875rem;font-weight:700;line-height:1.4;">Melhor cotação de ouro em {c.cidade}</h3>
            </div>

            <div style="text-align:center;padding:1.5rem;">
              <div style="width:3.5rem;height:3.5rem;border-radius:50%;background:rgba(223,176,58,0.1);display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#DFB03A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M11 15h2a2 2 0 1 0 0-4h-3c-.6 0-1.1.2-1.4.6L3 17"></path>
                  <path d="m7 21 1.6-1.4c.3-.4.8-.6 1.4-.6h4c1.1 0 2.1-.4 2.8-1.2l4.6-4.4a2 2 0 0 0-2.75-2.91l-4.2 3.9"></path>
                  <path d="m2 16 6 6"></path><circle cx="16" cy="9" r="2.9"></circle><circle cx="6" cy="5" r="3"></circle>
                </svg>
              </div>
              <h3 class="font-serif" style="font-size:0.875rem;font-weight:700;line-height:1.4;">Avaliação sem compromisso</h3>
            </div>

            <div style="text-align:center;padding:1.5rem;">
              <div style="width:3.5rem;height:3.5rem;border-radius:50%;background:rgba(223,176,58,0.1);display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#DFB03A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14z"></path>
                </svg>
              </div>
              <h3 class="font-serif" style="font-size:0.875rem;font-weight:700;line-height:1.4;">Pagamento imediato</h3>
            </div>

            <div style="text-align:center;padding:1.5rem;">
              <div style="width:3.5rem;height:3.5rem;border-radius:50%;background:rgba(223,176,58,0.1);display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#DFB03A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"></path>
                </svg>
              </div>
              <h3 class="font-serif" style="font-size:0.875rem;font-weight:700;line-height:1.4;">Atendimento seguro e discreto</h3>
            </div>

            <div style="text-align:center;padding:1.5rem;">
              <div style="width:3.5rem;height:3.5rem;border-radius:50%;background:rgba(223,176,58,0.1);display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#DFB03A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"></path>
                  <circle cx="12" cy="10" r="3"></circle>
                </svg>
              </div>
              <h3 class="font-serif" style="font-size:0.875rem;font-weight:700;line-height:1.4;">Localização central</h3>
            </div>

          </div>
        </div>
      </section>

      <!-- ===== BAIRROS ATENDIDOS ===== -->
      <section style="padding:3rem 1rem;background:#1a1a1a;border-top:1px solid #2a2a2a;">
        <div style="max-width:48rem;margin:0 auto;text-align:center;">
          <h2 class="font-serif" style="font-size:1.5rem;font-weight:700;margin-bottom:1.5rem;">
            Atendemos clientes de toda <span class="text-gradient-gold">{c.cidade} e região</span>
          </h2>
          <p style="color:#989181;font-size:0.9rem;margin-bottom:1.25rem;">
            Bairros e regiões atendidos: {c.bairrosAtendidos.join(', ')} e mais.
          </p>
          <p style="color:#989181;font-size:0.9rem;">
            Independente do bairro, venha até o centro de {c.cidade} e aproveite a melhor cotação de ouro da região.
          </p>
        </div>
      </section>

      <!-- ===== ONDE VENDER ===== -->
      <section style="padding:5rem 1rem;background:#121212;">
        <div style="max-width:48rem;margin:0 auto;text-align:center;">
          <h2 class="font-serif" style="font-size:clamp(1.75rem,3.5vw,2.5rem);font-weight:700;margin-bottom:1.5rem;">
            Onde vender ouro em <span class="text-gradient-gold">{c.cidade}</span>?
          </h2>
          <p style="color:#989181;font-size:1.125rem;line-height:1.75;margin-bottom:1.5rem;">{c.textosUnicos.ondeParagrafo}</p>
          <p style="color:#989181;line-height:1.75;margin-bottom:2rem;">{c.textosUnicos.ondeParagrafo2}</p>
          <a href={c.whatsappLink} target="_blank" rel="noopener noreferrer" class="btn-gold"
            style="display:inline-flex;align-items:center;gap:0.5rem;padding:0.75rem 1.5rem;font-size:1rem;font-weight:600;border-radius:0.5rem;text-decoration:none;color:#121212;">
            Entre em contato agora
          </a>
        </div>
      </section>

      <!-- ===== LOCALIZAÇÃO ===== -->
      <section id="localizacao" style="padding:5rem 1rem;background:#1a1a1a;">
        <div style="max-width:1280px;margin:0 auto;">
          <h2 class="font-serif" style="font-size:clamp(1.75rem,3.5vw,2.5rem);font-weight:700;text-align:center;margin-bottom:4rem;">
            Nossa <span class="text-gradient-gold">localização</span>
          </h2>
          <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:2rem;max-width:64rem;margin:0 auto;align-items:center;">
            <div style="display:flex;flex-direction:column;gap:1.5rem;">

              <div style="display:flex;align-items:flex-start;gap:1rem;">
                <div style="width:2.5rem;height:2.5rem;border-radius:50%;background:rgba(223,176,58,0.1);display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:0.25rem;">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#DFB03A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"></path>
                    <circle cx="12" cy="10" r="3"></circle>
                  </svg>
                </div>
                <div>
                  <h3 class="font-serif" style="font-size:1.125rem;font-weight:700;margin-bottom:0.25rem;">Endereço</h3>
                  <p style="color:#989181;">{c.endereco}<br />{c.complemento}<br />{c.cidade} – {c.estado}, {c.cep}</p>
                </div>
              </div>

              <div style="display:flex;align-items:flex-start;gap:1rem;">
                <div style="width:2.5rem;height:2.5rem;border-radius:50%;background:rgba(223,176,58,0.1);display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:0.25rem;">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#DFB03A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.21 12 19.79 19.79 0 0 1 1.14 3.33 2 2 0 0 1 3.1 1.14h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"></path>
                  </svg>
                </div>
                <div>
                  <h3 class="font-serif" style="font-size:1.125rem;font-weight:700;margin-bottom:0.25rem;">Telefone / WhatsApp</h3>
                  <a href={`tel:${c.telefoneRaw}`} style="color:#DFB03A;text-decoration:none;">{c.telefone}</a>
                </div>
              </div>

            </div>

            <div style="border-radius:0.75rem;overflow:hidden;border:1px solid #2a2a2a;height:20rem;">
              <iframe
                src={c.mapsEmbed}
                width="100%"
                height="100%"
                style="border:0;"
                allowfullscreen
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                title={`Localização Riviera - Compra de Ouro em ${c.cidade}`}
              ></iframe>
            </div>

          </div>
        </div>
      </section>

    </main>

    <!-- ===== FOOTER ===== -->
    <footer id="contato" style="padding:3rem 1rem;border-top:1px solid #2a2a2a;background:rgba(30,30,30,0.3);">
      <div style="max-width:1280px;margin:0 auto;">
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:2rem;align-items:start;">
          <div>
            <img src={assets.logo} alt="Riviera - Compra de Ouro e Acessórios" style="height:5rem;border-radius:0.375rem;margin-bottom:1rem;" />
            <p style="color:#989181;font-size:0.875rem;">{c.textosUnicos.footerTagline}</p>
          </div>
          <div>
            <h4 class="font-serif" style="font-weight:700;margin-bottom:0.75rem;">Endereço</h4>
            <p style="color:#989181;font-size:0.875rem;">{c.endereco}<br />{c.complemento}<br />{c.cidade} – {c.estado}, {c.cep}</p>
            <p style="color:#989181;font-size:0.875rem;margin-top:0.5rem;">Tel: {c.telefone}</p>
          </div>
          <div>
            <h4 class="font-serif" style="font-weight:700;margin-bottom:0.75rem;">Redes Sociais</h4>
            <a href={c.instagram} target="_blank" rel="noopener noreferrer"
              style="display:inline-flex;align-items:center;gap:0.5rem;color:#989181;text-decoration:none;font-size:0.875rem;">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect width="20" height="20" x="2" y="2" rx="5" ry="5"></rect>
                <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
                <line x1="17.5" x2="17.51" y1="6.5" y2="6.5"></line>
              </svg>
              {c.instagramHandle}
            </a>
          </div>
        </div>
        <div style="margin-top:2.5rem;padding-top:1.5rem;border-top:1px solid #2a2a2a;text-align:center;">
          <p style="color:#989181;font-size:0.75rem;">© 2026 Riviera – Compra de Ouro e Acessórios. Todos os direitos reservados.</p>
        </div>
      </div>
    </footer>

    <!-- ===== WhatsApp FAB ===== -->
    <a href={c.whatsappLink} target="_blank" rel="noopener noreferrer" aria-label="Falar no WhatsApp"
      style="position:fixed;bottom:1.5rem;right:1.5rem;z-index:50;width:3.5rem;height:3.5rem;background:#25D366;border-radius:50%;display:flex;align-items:center;justify-content:center;box-shadow:0 4px 16px rgba(37,211,102,0.4);text-decoration:none;transition:box-shadow 0.2s;">
      <svg viewBox="0 0 24 24" style="width:1.75rem;height:1.75rem;fill:white;">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
    </a>

  </div>
</Layout>

<style>
  @media (min-width: 1024px) {
    .desktop-nav { display: flex !important; }
    .mobile-menu-btn { display: none !important; }
    .desktop-cta { display: inline-flex !important; }
  }
  @media (min-width: 768px) {
    .items-grid { grid-template-columns: repeat(4, 1fr) !important; }
  }
  .btn-gold {
    background: linear-gradient(135deg, #DFB03A 0%, #F5D680 50%, #DFB03A 100%);
    transition: opacity 0.2s;
  }
  .btn-gold:hover { opacity: 0.9; }
  .card-dark:hover { border-color: rgba(223,176,58,0.3) !important; }
  .item-card:hover { border-color: rgba(223,176,58,0.3) !important; }
  .item-card:hover .item-img { transform: scale(1.05); }
</style>

<script>
  const btn = document.getElementById('menu-btn');
  const menu = document.getElementById('mobile-menu');
  if (btn && menu) {
    btn.addEventListener('click', () => {
      menu.style.display = menu.style.display === 'none' ? 'flex' : 'none';
    });
  }
</script>
